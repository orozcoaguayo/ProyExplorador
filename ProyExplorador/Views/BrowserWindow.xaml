<Window x:Class="ProyExplorador.Views.BrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Navegador Web"
        Width="1100" Height="760"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource FontMain}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="14"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.55"/>
        </Border.Effect>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button x:Name="BtnAtras" Content="←" Width="40" Height="34" Click="BtnAtras_Click" Style="{StaticResource BtnGhost}" ToolTip="Atrás"/>
                <Button x:Name="BtnAdelante" Content="→" Width="40" Height="34" Click="BtnAdelante_Click" Style="{StaticResource BtnGhost}" ToolTip="Adelante" Margin="6,0,0,0"/>
                <Button x:Name="BtnRecargar" Content="⟳" Width="40" Height="34" Click="BtnRecargar_Click" Style="{StaticResource BtnGhost}" ToolTip="Recargar" Margin="6,0,0,0"/>
                <Button x:Name="BtnInicio" Content="🏠" Width="40" Height="34" Click="BtnInicio_Click" Style="{StaticResource BtnGhost}" ToolTip="Inicio" Margin="6,0,0,0"/>

                <TextBox x:Name="TxtDireccion" Width="680" Height="34" Margin="12,0,0,0" VerticalAlignment="Center" Background="#16162A" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8,6" KeyDown="TxtDireccion_KeyDown" />
                <Button x:Name="BtnIr" Content="Ir" Width="60" Height="34" Margin="8,0,0,0" Click="BtnIr_Click" Style="{StaticResource BtnPrimary}"/>
            </StackPanel>

            <Border Grid.Row="1" CornerRadius="8" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Background="#0B0000" Margin="0,12,0,0">
                <Grid x:Name="WebHost">
                    <!-- WebView2 se creará en code-behind -->
                    <TextBlock Text="Cargando navegador..." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>