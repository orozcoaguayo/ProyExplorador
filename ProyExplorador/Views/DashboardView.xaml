<UserControl x:Class="ProyExplorador.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="768" d:DesignWidth="1060">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer Style="{StaticResource MinimalScrollViewer}" Padding="0"
                  VerticalScrollBarVisibility="Auto"
                  CanContentScroll="False"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>

            <!-- ══ HERO BANNER ══════════════════════════════════════════ -->
            <Border MinHeight="140" Margin="0,0,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0E0E18" Offset="0"/>
                        <GradientStop Color="#141428" Offset="0.5"/>
                        <GradientStop Color="#0E0E18" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="24,18,24,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <!-- Greeting grande -->
                        <TextBlock Text="{Binding Greeting}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CurrentDate}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,6,0,0"/>
                        <!-- Tags decorativos -->
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <Border Style="{StaticResource BadgeAccent}" Margin="0,0,8,0">
                                <TextBlock Text="Windows 11 Style" FontSize="11"
                                           Foreground="{StaticResource TextAccentBrush}"
                                           FontFamily="{StaticResource FontMain}"/>
                            </Border>

                <!-- badge success preserved -->
                            <Border Style="{StaticResource BadgeSuccess}">
                                <TextBlock Text=".NET 8 · WPF" FontSize="11"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontFamily="{StaticResource FontMain}"/>
                            </Border>
                            <Border Style="{StaticResource BadgeSuccess}">
                                <TextBlock Text=".NET 8 · WPF" FontSize="11"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontFamily="{StaticResource FontMain}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="↻  Actualizar"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource BtnGhost}"
                            VerticalAlignment="Center"
                            Padding="14,9"/>
                </Grid>
            </Border>

            <!-- Línea separadora con gradiente -->
            <Rectangle Height="1" Margin="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent"    Offset="0"/>
                        <GradientStop Color="#25253A"        Offset="0.3"/>
                        <GradientStop Color="#25253A"        Offset="0.7"/>
                        <GradientStop Color="Transparent"    Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Grid Margin="24,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ══ ACCESOS RÁPIDOS ══════════════════════════════════ -->
                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Accesos Rápidos"
                               Style="{StaticResource SubtitleText}"
                               FontSize="15"/>
                </DockPanel>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding QuickAccesses}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,0,12,12"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenFolderCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding Path}"
                                    Cursor="Hand"
                                    MinWidth="160"
                                    MinHeight="130">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CardBorder"
                                                MinWidth="160"
                                                MinHeight="130"
                                                Background="{StaticResource BgCardBrush}"
                                                CornerRadius="14"
                                                BorderBrush="Red"
                                                BorderThickness="1"
                                                Padding="16"
                                                SnapsToDevicePixels="True">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000" BlurRadius="10" ShadowDepth="1" Opacity="0.28"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding Icon}"
                                                           FontSize="24"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Name}"
                                                           FontFamily="{StaticResource FontMain}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Margin="0,12,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ══ ALMACENAMIENTO ════════════════════════════════════ -->
                <TextBlock Grid.Row="2" Text="Almacenamiento"
                           Style="{StaticResource SubtitleText}"
                           FontSize="15"
                           Margin="0,16,0,12"/>

                <ItemsControl Grid.Row="3" ItemsSource="{Binding Drives}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MinWidth="280" Margin="0,0,12,12"
                                    Background="{StaticResource BgCardBrush}"
                                    CornerRadius="14"
                                    BorderBrush="#10FFFFFF"
                                    BorderThickness="1"
                                    Padding="18,16">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="20" ShadowDepth="2" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,14">
                                        <Border Width="38" Height="38" CornerRadius="9"
                                                Margin="0,0,12,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#1E7C6DFA" Offset="0"/>
                                                    <GradientStop Color="#1E3EC9C0" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Icon}" FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Label}"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <ProgressBar Value="{Binding UsagePercent}"
                                                 Maximum="100"
                                                 Style="{StaticResource ModernProgressBar}"
                                                 Height="5"
                                                 Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Usado"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock Text="{Binding FormattedUsed}"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="Libre"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock Text="{Binding FormattedFree}"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ══ ARCHIVOS RECIENTES ════════════════════════════════ -->
                <TextBlock Grid.Row="4" Text="Recientes"
                           Style="{StaticResource SubtitleText}"
                           FontSize="15"
                           Margin="0,16,0,12"/>

                <Border Grid.Row="5"
                        Background="{StaticResource BgCardBrush}"
                        CornerRadius="14"
                        BorderBrush="#10FFFFFF"
                        BorderThickness="1"
                        Padding="6">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="18" ShadowDepth="2" Opacity="0.25"/>
                    </Border.Effect>
                    <ItemsControl ItemsSource="{Binding RecentFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="9" Padding="12,9" Margin="0,1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto" MinWidth="72"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="30" Height="30" CornerRadius="7"
                                                Background="#12FFFFFF" Grid.Column="0">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontFamily="{StaticResource FontMain}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TimeAgo}"
                                                   FontFamily="{StaticResource FontMain}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- ══ SISTEMA ═══════════════════════════════════════════ -->
                <Border Grid.Row="6"
                        Background="{StaticResource BgCardBrush}"
                        CornerRadius="14"
                        BorderBrush="#10FFFFFF"
                        BorderThickness="1"
                        Padding="18,14"
                        Margin="0,16,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="14" ShadowDepth="1" Opacity="0.22"/>
                    </Border.Effect>
                    <DockPanel>
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E4AA8F0" Offset="0"/>
                                    <GradientStop Color="#1E3EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="💻" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" MinWidth="0">
                            <TextBlock Text="Información del Sistema"
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding SystemInfo}"
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>