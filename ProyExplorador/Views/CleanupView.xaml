<UserControl x:Class="ProyExplorador.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="768" d:DesignWidth="1060">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer Style="{StaticResource MinimalScrollViewer}">
        <StackPanel>

            <!-- Hero -->
            <Border MinHeight="110">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0E0E18" Offset="0"/>
                        <GradientStop Color="#141428" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Margin="36,26,36,26">
                    <TextBlock Text="Limpieza del Sistema"
                               FontFamily="{StaticResource FontMain}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Libera espacio eliminando archivos innecesarios y caché del sistema."
                               FontFamily="{StaticResource FontMain}"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Margin="28,24,28,28">

                <!-- ── PROGRESO ACTIVO ─────────────────────────────── -->
                <Border Background="{StaticResource BgCardBrush}"
                        CornerRadius="14" BorderBrush="#10FFFFFF" BorderThickness="1"
                        Padding="22,18" Margin="0,0,0,20"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border.Effect>
                        <DropShadowEffect Color="#7C6DFA" BlurRadius="22" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentFile}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,8"/>
                        <ProgressBar Value="{Binding CleanProgress}"
                                     Maximum="100"
                                     Style="{StaticResource ModernProgressBar}"
                                     Height="6"
                                     Margin="0,0,0,8"/>
                        <TextBlock FontFamily="{StaticResource FontMain}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding CleanProgress, StringFormat='{}{0:F0}'}"/>
                            <Run Text="% completado"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ── TARJETAS DE LIMPIEZA ───────────────────────── -->
                <UniformGrid Columns="2" Margin="0,0,0,16">

                    <!-- Temporales -->
                    <Border MinWidth="220" Margin="0,0,10,10"
                            Background="{StaticResource BgCardBrush}"
                            CornerRadius="14" BorderBrush="#10FFFFFF" BorderThickness="1"
                            Padding="22,20">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" BlurRadius="18" ShadowDepth="2" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="11"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#26F0A732" Offset="0"/>
                                        <GradientStop Color="#14F05252" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📁" FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Archivos Temporales"
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock FontFamily="{StaticResource FontMain}"
                                       FontSize="13" Margin="0,0,0,4">
                                <Run Text="Tamaño: " Foreground="{StaticResource TextMutedBrush}"/>
                                <Run Text="{Binding TempSizeFormatted}" Foreground="{StaticResource WarningBrush}"
                                     FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Text="Archivos en %TEMP% y carpetas temporales del sistema."
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Calcular"
                                        Command="{Binding CalculateSizeCommand}"
                                        Style="{StaticResource BtnGhost}"
                                        Padding="12,7" FontSize="12"/>
                                <Button Content="Limpiar"
                                        Command="{Binding CleanTempCommand}"
                                        Style="{StaticResource BtnPrimary}"
                                        Padding="14,7" FontSize="12"
                                        Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Papelera -->
                    <Border MinWidth="220" Margin="10,0,0,10"
                            Background="{StaticResource BgCardBrush}"
                            CornerRadius="14" BorderBrush="#10FFFFFF" BorderThickness="1"
                            Padding="22,20">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" BlurRadius="18" ShadowDepth="2" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="11"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#26F05252" Offset="0"/>
                                        <GradientStop Color="#14F0A732" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🗑️" FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Papelera de Reciclaje"
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Vaciar todos los archivos de la papelera de reciclaje."
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>
                            <Button Content="Vaciar papelera"
                                    Command="{Binding EmptyRecycleBinCommand}"
                                    Style="{StaticResource BtnPrimary}"
                                    Padding="14,7" FontSize="12"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Resultado -->
                <Border Background="{StaticResource BgCardBrush}"
                        CornerRadius="12" BorderBrush="#10FFFFFF" BorderThickness="1"
                        Padding="18,14"
                        Visibility="{Binding FreedSpaceText,
                            Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                    <DockPanel>
                        <Border Width="36" Height="36" CornerRadius="9" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#264CAF7A" Offset="0"/>
                                    <GradientStop Color="#143EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="✅" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Limpieza completada"
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding FreedSpaceText}"
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="12"
                                       Foreground="{StaticResource SuccessBrush}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>