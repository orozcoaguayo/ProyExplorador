<Window x:Class="ProyExplorador.Views.DataViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Visualizador y Analizador de Datos"
        Width="1200" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource FontMain}">

    <Border CornerRadius="14"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.55"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel actions -->
            <StackPanel Grid.Column="0">
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold">Visualizador y Analizador de Datos</TextBlock>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0">Carga y analiza datos desde múltiples formatos.</TextBlock>
                    </StackPanel>
                </Border>

                <Button x:Name="BtnLoadFile" Content="Cargar Archivo" Style="{StaticResource BtnPrimary}" Height="40" Margin="0,0,0,8" Click="BtnLoadFile_Click"/>
                <Button x:Name="BtnShowContent" Content="Ver Contenido" Style="{StaticResource BtnGhost}" Height="36" Margin="0,0,0,8" Click="BtnShowContent_Click"/>
                <Button x:Name="BtnShowTable" Content="Ver Tabla" Style="{StaticResource BtnGhost}" Height="36" Margin="0,0,0,8" Click="BtnShowTable_Click"/>
                <Button x:Name="BtnBarChart" Content="Gráfica de Barras" Style="{StaticResource BtnGhost}" Height="36" Margin="0,0,0,8" Click="BtnBarChart_Click"/>
                <Button x:Name="BtnPieChart" Content="Gráfica de Pastel" Style="{StaticResource BtnGhost}" Height="36" Margin="0,0,0,8" Click="BtnPieChart_Click"/>

                <Border Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="8" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Info" FontWeight="SemiBold"/>
                        <TextBlock Text="Archivo:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtFileName" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Registros:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtRecordsCount"/>
                        <TextBlock Text="Tipo:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtDetectedType"/>
                        <TextBlock Text="Cargado:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtLoadedAt"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right content -->
            <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock FontSize="16" FontWeight="SemiBold" x:Name="TxtViewTitle">Visualizador y Analizador de Datos</TextBlock>
                        <TextBlock Text=" - " Margin="6,0"/>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" x:Name="TxtViewSubtitle">Carga, analiza y muestra datos</TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <TextBox x:Name="TxtContent" Visibility="Collapsed" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas"/>

                        <DataGrid x:Name="GridTable" Visibility="Collapsed" AutoGenerateColumns="True" CanUserAddRows="False" IsReadOnly="True"/>

                        <Grid x:Name="ChartArea" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Chart header info -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Grid.Row="0" x:Name="ChartHeader" Visibility="Collapsed">
                                <TextBlock Text="Archivo:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock x:Name="ChartFileName" Margin="0,0,12,0"/>
                                <TextBlock Text="Registros:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock x:Name="ChartRecords" Margin="0,0,12,0"/>
                                <TextBlock Text="Categoría:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock x:Name="ChartCategory" Margin="0,0,12,0"/>
                                <TextBlock Text="Valor:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock x:Name="ChartValueCol"/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <lvc:CartesianChart x:Name="BarChart" Grid.Column="0" Visibility="Collapsed" />
                                <lvc:PieChart x:Name="PieChart" Grid.Column="1" Visibility="Collapsed" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
