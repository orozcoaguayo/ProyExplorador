<UserControl x:Class="ProyExplorador.Views.FileReaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ProyExplorador.ViewModels"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="768" d:DesignWidth="1100">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- ══ TOOLBAR ══════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecondaryBrush}"
                Padding="16,10"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Icono y nombre -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="📖" FontSize="18"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="11"
                                   Margin="0,2,0,0">
                            <Run Text="{Binding FileExtension, FallbackValue='—'}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding LineCount, StringFormat='{}{0} líneas'}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Botones derecha -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📂  Abrir Archivo"
                            Command="{Binding OpenFileDialogCommand}"
                            Style="{StaticResource BtnPrimary}"
                            Padding="14,8"
                            FontSize="12"
                            Margin="0,0,8,0"/>
                    <Button Content="✕  Cerrar"
                            Command="{Binding CloseFileCommand}"
                            Style="{StaticResource BtnGhost}"
                            Padding="12,8"
                            FontSize="12"
                            Visibility="{Binding HasContent,
                                Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ ÁREA DE CONTENIDO ════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- Estado vacío -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding HasContent,
                            Converter={StaticResource BoolToVisibilityConverter},
                            ConverterParameter=inverse}">
                <TextBlock Text="📖" FontSize="64"
                           HorizontalAlignment="Center" Opacity="0.2"/>
                <TextBlock Text="Lector de Archivos"
                           Style="{StaticResource SubtitleText}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,8" Opacity="0.5"/>
                <TextBlock Text="Soporta TXT · JSON · XML · CSV · DOCX · XLSX · PPTX · PNG · JPG · GIF · BMP"
                           Style="{StaticResource BodyText}"
                           HorizontalAlignment="Center"
                           Opacity="0.35"/>
                <Button Content="📂  Abrir Archivo"
                        Command="{Binding OpenFileDialogCommand}"
                        Style="{StaticResource BtnPrimary}"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,0"
                        Padding="20,10"/>
            </StackPanel>

            <!-- ── TXT / LOG ─────────────────────────────────────────── -->
            <Border Background="{StaticResource BgPrimaryBrush}"
                    Visibility="{Binding FileType,
                        Converter={StaticResource ViewModeToVisibilityConverter},
                        ConverterParameter=txt}">
                <Grid>
                    <!-- Números de línea + contenido -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Panel de números de línea -->
                    <Border Grid.Column="0"
                            Background="#0A0A0D"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="0,0,1,0">
                        <ScrollViewer x:Name="LineScroll"
                                      Style="{StaticResource MinimalScrollViewer}"
                                      VerticalScrollBarVisibility="Hidden">
                            <ItemsControl x:Name="LineNumbers">
                                <!-- Generado desde code-behind -->
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Contenido de texto -->
                    <ScrollViewer Grid.Column="1"
                                  Style="{StaticResource MinimalScrollViewer}"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding RawContent, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 CaretBrush="Transparent"
                                 BorderThickness="0"
                                 FontFamily="{StaticResource FontMono}"
                                 FontSize="13"
                                 Padding="16,12"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 SelectionBrush="{StaticResource AccentBrush}"
                                 SelectionOpacity="0.3"
                                 VerticalScrollBarVisibility="Hidden"
                                 HorizontalScrollBarVisibility="Hidden"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── JSON ──────────────────────────────────────────────── -->
            <Grid Visibility="{Binding FileType,
                      Converter={StaticResource ViewModeToVisibilityConverter},
                      ConverterParameter=json}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Árbol JSON -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgPrimaryBrush}">
                    <ScrollViewer Style="{StaticResource MinimalScrollViewer}" Padding="12">
                        <TreeView ItemsSource="{Binding TreeNodes}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource DarkTreeViewItem}">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type vm:TreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Border Background="#252535"
                                                CornerRadius="4"
                                                Padding="4,2"
                                                Margin="0,0,6,0">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="{StaticResource FontMono}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" : "
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding Value,
                                                       Converter={StaticResource NullOrEmptyToVisibilityConverter},
                                                       ConverterParameter=invert}"/>
                                        <TextBlock Text="{Binding Value}"
                                                   Foreground="#F8C66A"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding Value,
                                                       Converter={StaticResource NullOrEmptyToVisibilityConverter},
                                                       ConverterParameter=invert}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Border>

                <!-- Divisor -->
                <Border Grid.Column="1" Background="{StaticResource SeparatorBrush}"/>

                <!-- JSON raw formateado -->
                <Border Grid.Column="2"
                        Background="#0A0A0D">
                    <ScrollViewer Style="{StaticResource MinimalScrollViewer}">
                        <TextBox Text="{Binding PrettyJson, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 Foreground="#A9DC76"
                                 CaretBrush="Transparent"
                                 BorderThickness="0"
                                 FontFamily="{StaticResource FontMono}"
                                 FontSize="12"
                                 Padding="14,12"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Hidden"
                                 HorizontalScrollBarVisibility="Hidden"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── XML ───────────────────────────────────────────────── -->
            <Grid Visibility="{Binding FileType,
                      Converter={StaticResource ViewModeToVisibilityConverter},
                      ConverterParameter=xml}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Árbol XML -->
                <Border Grid.Column="0" Background="{StaticResource BgPrimaryBrush}">
                    <ScrollViewer Style="{StaticResource MinimalScrollViewer}" Padding="12">
                        <TreeView ItemsSource="{Binding TreeNodes}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource DarkTreeViewItem}">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type vm:TreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Foreground="#66D9EF"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center">
                                            <Run Text="&lt;"/><Run Text="{Binding Label}"/><Run Text="&gt;"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Value}"
                                                   Foreground="#E6DB74"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="12"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding Value,
                                                       Converter={StaticResource NullOrEmptyToVisibilityConverter},
                                                       ConverterParameter=invert}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource SeparatorBrush}"/>

                <!-- XML raw -->
                <Border Grid.Column="2" Background="#0A0A0D">
                    <ScrollViewer Style="{StaticResource MinimalScrollViewer}">
                        <TextBox Text="{Binding RawContent, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 Foreground="#66D9EF"
                                 CaretBrush="Transparent"
                                 BorderThickness="0"
                                 FontFamily="{StaticResource FontMono}"
                                 FontSize="12"
                                 Padding="14,12"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Hidden"
                                 HorizontalScrollBarVisibility="Hidden"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── CSV ───────────────────────────────────────────────── -->
            <Border Background="{StaticResource BgPrimaryBrush}"
                    Visibility="{Binding FileType,
                        Converter={StaticResource ViewModeToVisibilityConverter},
                        ConverterParameter=csv}">
                <ScrollViewer Style="{StaticResource MinimalScrollViewer}"
                              HorizontalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Encabezado CSV -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BgSecondaryBrush}"
                                Padding="0,0,0,1">
                            <ItemsControl x:Name="CsvHeaderRow"
                                          ItemsSource="{Binding CsvHeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="160"
                                                Padding="12,8"
                                                BorderBrush="{StaticResource SeparatorBrush}"
                                                BorderThickness="0,0,1,1">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Filas CSV -->
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CsvRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="RowBorder"
                                            BorderBrush="{StaticResource SeparatorBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource BgHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ItemsControl ItemsSource="{Binding DataContext.CsvHeaders,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="160"
                                                            Padding="12,7"
                                                            BorderBrush="{StaticResource SeparatorBrush}"
                                                            BorderThickness="0,0,1,0">
                                                        <TextBlock Text="{Binding}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontFamily="{StaticResource FontMono}"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Border>

            <!-- ── IMAGE (png / jpg / gif / bmp / webp / tiff) ─────────── -->
            <Grid Visibility="{Binding FileType,
                      Converter={StaticResource ViewModeToVisibilityConverter},
                      ConverterParameter=image}"
                  Background="{StaticResource BgPrimaryBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Barra info imagen -->
                <Border Grid.Row="0"
                        Background="{StaticResource BgSecondaryBrush}"
                        Padding="16,8"
                        BorderBrush="{StaticResource SeparatorBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding FileExtension}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource FontMono}"
                                   FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  —  "
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Imagen centrada con scroll -->
                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Style="{StaticResource MinimalScrollViewer}">
                    <Image Source="{Binding ImagePath}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="24"/>
                </ScrollViewer>
            </Grid>

            <!-- ── OFFICE (docx / xlsx / pptx) ──────────────────────── -->
            <Grid Visibility="{Binding FileType,
                      Converter={StaticResource ViewModeToVisibilityConverter},
                      ConverterParameter=office}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource BgSecondaryBrush}"
                        Padding="16,8"
                        BorderBrush="{StaticResource SeparatorBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding FileExtension}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource FontMono}"
                                   FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  —  Contenido extraído (solo texto)"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1"
                              Style="{StaticResource MinimalScrollViewer}"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBox Text="{Binding RawContent, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             CaretBrush="Transparent"
                             BorderThickness="0"
                             FontFamily="{StaticResource FontMain}"
                             FontSize="13"
                             Padding="24,16"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             SelectionBrush="{StaticResource AccentBrush}"
                             SelectionOpacity="0.3"
                             VerticalScrollBarVisibility="Hidden"
                             HorizontalScrollBarVisibility="Hidden"/>
                </ScrollViewer>
            </Grid>

            <!-- ── ERROR ─────────────────────────────────────────────── -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding FileType,
                            Converter={StaticResource ViewModeToVisibilityConverter},
                            ConverterParameter=error}">
                <TextBlock Text="⚠️" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Style="{StaticResource BodyText}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,12,0,0"
                           MaxWidth="400"
                           Foreground="{StaticResource DangerBrush}"/>
            </StackPanel>

            <!-- ── BUSY SPINNER ──────────────────────────────────────── -->
            <Border Background="#AA000000"
                    Visibility="{Binding IsBusy,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource BodyText}"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
