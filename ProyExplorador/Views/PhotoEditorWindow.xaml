<Window x:Class="ProyExplorador.Views.PhotoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor de Fotos"
        Width="1200" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Estilo para botones de toolbar -->
            <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="2,0"/>
                <Setter Property="FontSize" Value="16"/>
            </Style>

            <!-- Estilo para separadores de toolbar -->
            <Style x:Key="ToolbarSeparator" TargetType="Border">
                <Setter Property="Width" Value="1"/>
                <Setter Property="Background" Value="#1CFFFFFF"/>
                <Setter Property="Margin" Value="8,8"/>
            </Style>

            <!-- ScrollViewer minimalista para el panel lateral -->
            <Style x:Key="MinimalScrollViewer" TargetType="ScrollViewer">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollViewer">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ScrollContentPresenter Grid.Column="0"/>
                                <ScrollBar x:Name="PART_VerticalScrollBar"
                                           Grid.Column="1"
                                           Orientation="Vertical"
                                           Value="{TemplateBinding VerticalOffset}"
                                           Maximum="{TemplateBinding ScrollableHeight}"
                                           ViewportSize="{TemplateBinding ViewportHeight}"
                                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                           Width="4" Opacity="0.3"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Marco principal con sombra -->
    <Border CornerRadius="14"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="50" ShadowDepth="10" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="598*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 TITLEBAR
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseDown="TitleBar_MouseDown" Grid.ColumnSpan="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F0F16" Offset="0"/>
                        <GradientStop Color="#13131C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + Título -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                        <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C6DFA" Offset="0"/>
                                    <GradientStop Color="#3EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🖼️" Foreground="White" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Editor de Fotos"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtFileName" Text="Sin archivo"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Controles de ventana -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,10,0">
                        <Button Content="─" Click="BtnMinimize_Click"
                                Style="{StaticResource BtnGhost}"
                                Width="34" Height="34" FontSize="11" ToolTip="Minimizar"/>
                        <Button Content="⬜" Click="BtnMaximize_Click"
                                Style="{StaticResource BtnGhost}"
                                Width="34" Height="34" FontSize="10" Margin="2,0" ToolTip="Maximizar"/>
                        <Button Content="✕" Click="BtnClose_Click"
                                Width="34" Height="34" FontSize="11" ToolTip="Cerrar">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BF3030"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 TOOLBAR
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="1" Background="{StaticResource BgSecondaryBrush}"
                    BorderBrush="#12FFFFFF" BorderThickness="0,0,0,1" Padding="12,0" Grid.ColumnSpan="2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Archivo -->
                    <Button Content="📂" Click="BtnOpen_Click" Style="{StaticResource ToolbarButton}" ToolTip="Abrir imagen"/>
                    <Button Content="💾" Click="BtnSave_Click" Style="{StaticResource ToolbarButton}" ToolTip="Guardar"/>
                    <Button Content="📥" Click="BtnSaveAs_Click" Style="{StaticResource ToolbarButton}" ToolTip="Guardar como..."/>

                    <Border Style="{StaticResource ToolbarSeparator}"/>

                    <!-- Rotación -->
                    <Button Content="↶" Click="BtnRotateLeft_Click" Style="{StaticResource ToolbarButton}" ToolTip="Rotar izquierda"/>
                    <Button Content="↷" Click="BtnRotateRight_Click" Style="{StaticResource ToolbarButton}" ToolTip="Rotar derecha"/>
                    <Button Content="⇄" Click="BtnFlipHorizontal_Click" Style="{StaticResource ToolbarButton}" ToolTip="Voltear horizontal"/>
                    <Button Content="⇅" Click="BtnFlipVertical_Click" Style="{StaticResource ToolbarButton}" ToolTip="Voltear vertical"/>

                    <Border Style="{StaticResource ToolbarSeparator}"/>

                    <!-- Filtros -->
                    <Button Content="🎨" Click="BtnGrayscale_Click" Style="{StaticResource ToolbarButton}" ToolTip="Escala de grises"/>
                    <Button Content="🌓" Click="BtnNegative_Click" Style="{StaticResource ToolbarButton}" ToolTip="Negativo"/>

                    <Border Style="{StaticResource ToolbarSeparator}"/>

                    <!-- Zoom -->
                    <Button Content="🔍+" Click="BtnZoomIn_Click" Style="{StaticResource ToolbarButton}" ToolTip="Acercar"/>
                    <Button Content="🔍−" Click="BtnZoomOut_Click" Style="{StaticResource ToolbarButton}" ToolTip="Alejar"/>
                    <Button Content="⊡" Click="BtnZoomFit_Click" Style="{StaticResource ToolbarButton}" ToolTip="Ajustar a ventana"/>

                    <Border Style="{StaticResource ToolbarSeparator}"/>

                    <!-- Reset -->
                    <Button Content="↺" Click="BtnReset_Click" Style="{StaticResource ToolbarButton}" ToolTip="Restablecer"/>

                    <!-- Brillo (derecha) -->
                    <Border Margin="20,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☀ Brillo" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider x:Name="SliderBrightness" Width="150" Minimum="-100" Maximum="100" Value="0"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="SliderBrightness_ValueChanged"/>
                            <TextBlock x:Name="TxtBrightness" Text="0" Width="30"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 ÁREA PRINCIPAL: IMAGEN + PANEL DERECHO
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Visor de imagen -->
                <Border Grid.Column="0" Background="#080810">
                    <Grid>
                        <!-- ScrollViewer con zoom -->
                        <ScrollViewer x:Name="ImageScrollViewer"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="Transparent">
                            <Border x:Name="ImageContainer"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Image x:Name="MainImage"
                                       Stretch="None"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </ScrollViewer>

                        <!-- Overlay "Sin imagen" -->
                        <Border x:Name="NoImageOverlay" Background="{StaticResource BgPrimaryBrush}"
                                Visibility="Visible">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🖼️" FontSize="64" Opacity="0.25"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No hay imagen cargada"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="14" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                                <TextBlock Text="Haz clic en Abrir o arrastra una imagen aquí"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Indicador de zoom -->
                        <Border Background="#CC000000" CornerRadius="8" Padding="12,6"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,16,16">
                            <TextBlock x:Name="TxtZoom" Text="100%"
                                       Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════════
                     PANEL LATERAL — PROPIEDADES E INSPECTOR
                ══════════════════════════════════════════════════════ -->
                <Border Grid.Column="1"
                        Background="{StaticResource BgSecondaryBrush}"
                        BorderBrush="#14FFFFFF" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Encabezado del panel -->
                        <Border Grid.Row="0" Padding="16,12,16,10"
                                BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#14141E" Offset="0"/>
                                    <GradientStop Color="#0F0F18" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="20" Height="20" CornerRadius="5" Margin="0,0,8,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C6DFA" Offset="0"/>
                                            <GradientStop Color="#3EC9C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="ℹ" FontSize="11" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="INSPECTOR"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="11" FontWeight="Bold"

                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Contenido scrollable -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Style="{StaticResource MinimalScrollViewer}">
                            <StackPanel Margin="12,12,12,16">

                                <!-- ─────────────────────────────────────────
                                     SECCIÓN 1 — INFORMACIÓN GENERAL
                                ───────────────────────────────────────────── -->
                                <Border Background="{StaticResource BgCardBrush}"
                                        CornerRadius="10" Padding="12" Margin="0,0,0,10"
                                        BorderBrush="#0EFFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Encabezado de sección -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Width="3" CornerRadius="2"
                                                    Margin="0,0,8,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#7C6DFA"/>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock Text="Información General"
                                                       Foreground="#7C6DFA"
                                                       FontSize="10" FontWeight="Bold"
                                                       VerticalAlignment="Center"
/>
                                        </StackPanel>

                                        <!-- Nombre -->
                                        <TextBlock Text="NOMBRE"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                        <TextBlock x:Name="PropFileName" Text="—"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="11" Margin="0,0,0,9"
                                                   TextWrapping="Wrap" TextTrimming="None"/>

                                        <!-- Separador -->
                                        <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                        <!-- Ruta -->
                                        <TextBlock Text="RUTA"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                        <TextBlock x:Name="PropFilePath" Text="—"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="10" Margin="0,0,0,9"
                                                   TextWrapping="Wrap"/>

                                        <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                        <!-- Extensión y Tamaño en fila -->
                                        <Grid Margin="0,0,0,9">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="EXTENSIÓN"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                <Border Background="#1A7C6DFA" CornerRadius="4"
                                                        Padding="6,3" HorizontalAlignment="Left">
                                                    <TextBlock x:Name="PropExtension" Text="—"
                                                               Foreground="#9D91FB"
                                                               FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="TAMAÑO"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                <TextBlock x:Name="PropFileSize" Text="—"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                        <!-- Fechas en fila -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="CREADO"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                <TextBlock x:Name="PropCreated" Text="—"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="10" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="MODIFICADO"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                <TextBlock x:Name="PropModified" Text="—"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="10" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ─────────────────────────────────────────
                                     SECCIÓN 2 — INFORMACIÓN DE IMAGEN
                                ───────────────────────────────────────────── -->
                                <Border Background="{StaticResource BgCardBrush}"
                                        CornerRadius="10" Padding="12" Margin="0,0,0,10"
                                        BorderBrush="#0EFFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Encabezado -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Width="3" CornerRadius="2"
                                                    Margin="0,0,8,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#3EC9C0"/>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock Text="Información de Imagen"
                                                       Foreground="#3EC9C0"
                                                       FontSize="10" FontWeight="Bold"
                                                       VerticalAlignment="Center"
/>
                                        </StackPanel>

                                        <!-- Resolución — destacada -->
                                        <TextBlock Text="RESOLUCIÓN"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                        <TextBlock x:Name="PropResolution" Text="—"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Margin="0,0,0,9"/>

                                        <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                        <!-- DPI X / DPI Y en fila -->
                                        <Grid Margin="0,0,0,9">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="DPI X"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                <TextBlock x:Name="PropDpiX" Text="—"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="DPI Y"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                <TextBlock x:Name="PropDpiY" Text="—"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                        <!-- Formato / Profundidad en fila -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="FORMATO"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                <TextBlock x:Name="PropFormat" Text="—"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="COLOR"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                <TextBlock x:Name="PropColorDepth" Text="—"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ─────────────────────────────────────────
                                     SECCIÓN 3 — METADATOS EXIF
                                ───────────────────────────────────────────── -->
                                <Border Background="{StaticResource BgCardBrush}"
                                        CornerRadius="10" Padding="12" Margin="0,0,0,10"
                                        BorderBrush="#0EFFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Encabezado -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Width="3" CornerRadius="2"
                                                    Margin="0,0,8,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#F0A732"/>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock Text="Metadatos EXIF"
                                                       Foreground="#F0A732"
                                                       FontSize="10" FontWeight="Bold"
                                                       VerticalAlignment="Center"
/>
                                        </StackPanel>

                                        <!-- Panel con datos EXIF — se muestra si existen -->
                                        <StackPanel x:Name="ExifDataPanel" Visibility="Collapsed">
                                            <!-- Cámara -->
                                            <TextBlock Text="CÁMARA"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                            <TextBlock x:Name="PropExifMake" Text="—"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" Margin="0,0,0,9"/>

                                            <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                            <!-- Modelo -->
                                            <TextBlock Text="MODELO"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                            <TextBlock x:Name="PropExifModel" Text="—"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" Margin="0,0,0,9"
                                                       TextWrapping="Wrap"/>

                                            <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                            <!-- Fecha captura -->
                                            <TextBlock Text="FECHA DE CAPTURA"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                            <TextBlock x:Name="PropExifDateTaken" Text="—"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" Margin="0,0,0,9"/>

                                            <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                            <!-- ISO / Apertura en fila -->
                                            <Grid Margin="0,0,0,9">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="ISO"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                    <TextBlock x:Name="PropExifISO" Text="—"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="APERTURA"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                                    <TextBlock x:Name="PropExifAperture" Text="—"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,9"/>

                                            <!-- GPS -->
                                            <TextBlock Text="GPS"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9" FontWeight="SemiBold"
 Margin="0,0,0,3"/>
                                            <TextBlock x:Name="PropExifGps" Text="—"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Sin EXIF -->
                                        <Border x:Name="ExifEmptyPanel"
                                                Background="#0A7C6DFA" CornerRadius="6"
                                                Padding="10,8" Visibility="Visible">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="ℹ" Foreground="#7C6DFA"
                                                           FontSize="13" Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="No hay metadatos disponibles."
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="11" TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 BARRA DE ESTADO
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="3" Background="{StaticResource BgTertiaryBrush}"
                    BorderBrush="#12FFFFFF" BorderThickness="0,1,0,0"
