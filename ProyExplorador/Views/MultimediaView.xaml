<UserControl x:Class="ProyExplorador.Views.MultimediaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="768" d:DesignWidth="1060">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="300"/>
            <ColumnDefinition Width="280" MinWidth="240" MaxWidth="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══ REPRODUCTOR (izquierda) ═══════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#08080D" Offset="0"/>
                    <GradientStop Color="#0C0C12" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Canvas de vídeo / portada -->
            <Border Grid.Row="0" Background="#050508">
                <Grid>
                    <!-- Video player (para videos) -->
                    <MediaElement x:Name="MediaPlayer"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  Stretch="Uniform"
                                  Volume="{Binding Volume}"
                                  IsMuted="{Binding IsMuted}"
                                  MediaOpened="MediaPlayer_MediaOpened"
                                  MediaEnded="MediaPlayer_MediaEnded"/>

                    <!-- Album Cover (para música) -->
                    <Image x:Name="AlbumArtwork"
                           Source="{Binding AlbumArtwork}"
                           Stretch="UniformToFill"
                           Opacity="0.9"/>

                    <!-- Fallback si no hay carátula -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAlbumArt}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="140" Height="140" CornerRadius="18" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E7C6DFA" Offset="0"/>
                                    <GradientStop Color="#1E3EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🎵" FontSize="70"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.6"/>
                        </Border>
                    </StackPanel>

                    <!-- Estado vacío (sin reproducción) -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding CurrentFilePath,
                                    Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                        <Border Width="100" Height="100" CornerRadius="18" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E7C6DFA" Offset="0"/>
                                    <GradientStop Color="#1E3EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🎬" FontSize="50"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.45"/>
                        </Border>
                        <TextBlock Text="Sin reproducción"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Opacity="0.55"/>
                        <Button Content="  Abrir archivo  "
                                Command="{Binding OpenFolderCommand}"
                                Style="{StaticResource BtnPrimary}"
                                Padding="22,10" FontSize="13"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Controles — glassmorphism panel -->
            <Border Grid.Row="1"
                    BorderBrush="#15FFFFFF"
                    BorderThickness="0,1,0,0"
                    Padding="26,18,26,22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0D0D16" Offset="0"/>
                        <GradientStop Color="#0A0A12" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <!-- Nombre del archivo -->
                    <TextBlock Text="{Binding CurrentFileName}"
                               FontFamily="{StaticResource FontMain}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="400"
                               Margin="0,0,0,14"/>

                    <!-- Progreso -->
                    <Slider x:Name="ProgressSlider"
                            Minimum="0" Maximum="{Binding Duration}"
                            Value="{Binding Position, Mode=TwoWay}"
                            Style="{StaticResource MediaSlider}"
                            Margin="0,0,0,5"
                            ValueChanged="ProgressSlider_ValueChanged"/>

                    <DockPanel Margin="0,0,0,18">
                        <TextBlock Text="{Binding PositionText}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding DurationText}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Right"/>
                    </DockPanel>

                    <!-- Botones centrales -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="⏮" Command="{Binding PreviousCommand}"
                                Style="{StaticResource BtnGhost}"
                                Width="44" Height="44" FontSize="19"/>
                        <Border Width="56" Height="56" CornerRadius="28" Margin="14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C6DFA" Offset="0"/>
                                    <GradientStop Color="#3EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#7C6DFA" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <Button Command="{Binding TogglePlayPauseCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Width="56" Height="56">
                                <TextBlock Text="{Binding IsPlaying,
                                               Converter={StaticResource BoolToPlayPauseConverter}}"
                                           FontSize="20" Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </Border>
                        <Button Content="⏭" Command="{Binding NextCommand}"
                                Style="{StaticResource BtnGhost}"
                                Width="44" Height="44" FontSize="19"/>
                        <Button Content="⏹" Command="{Binding StopCommand}"
                                Style="{StaticResource BtnGhost}"
                                Width="44" Height="44" FontSize="18" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Volumen -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Button Content="{Binding IsMuted, Converter={StaticResource BoolToMuteIconConverter}}"
                                Command="{Binding ToggleMuteCommand}"
                                Style="{StaticResource BtnGhost}"
                                Width="30" Height="30" FontSize="14" Margin="0,0,8,0"/>
                        <Slider Minimum="0" Maximum="1"
                                Value="{Binding Volume, Mode=TwoWay}"
                                Style="{StaticResource MediaSlider}"
                                MinWidth="90" Width="110" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Volume, StringFormat='{}{0:P0}'}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="32"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Divisor luminoso -->
        <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent"  Offset="0"/>
                    <GradientStop Color="#18FFFFFF"    Offset="0.5"/>
                    <GradientStop Color="Transparent"  Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ══ PLAYLIST (derecha) ════════════════════════════════════ -->
        <Border Grid.Column="1" Background="{StaticResource BgSecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <Border Grid.Row="0"
                        Padding="16,14"
                        BorderBrush="{StaticResource SeparatorBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="Playlist"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="＋ Agregar"
                                Command="{Binding OpenFolderCommand}"
                                Style="{StaticResource BtnPrimary}"
                                Padding="12,6" FontSize="12"
                                DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>

                <!-- Elementos -->
                <ListView Grid.Row="1"
                          ItemsSource="{Binding Playlist}"
                          Style="{StaticResource ModernListView}"
                          Padding="8,4">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.PlayItemCommand,
                                              RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Cursor="Hand" Padding="0">
                                <Border CornerRadius="8" Padding="10,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   Margin="0,0,10,0" Width="22"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding FormattedSize}"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>