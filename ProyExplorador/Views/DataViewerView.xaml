<UserControl x:Class="ProyExplorador.Views.DataViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ProyExplorador.ViewModels"
             xmlns:lvc="http://livecharts.co.uk/wpf"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: acciones -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0">
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontFamily="{StaticResource FontMain}" FontSize="16" FontWeight="SemiBold">Visualizador y Analizador de Datos</TextBlock>
                    <TextBlock FontFamily="{StaticResource FontMain}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0">Carga, analiza y visualiza información desde múltiples formatos de archivo.</TextBlock>
                </StackPanel>
            </Border>

            <Button x:Name="BtnLoad" Content="Cargar Archivo" Style="{StaticResource BtnPrimary}" Height="40" Margin="0,0,0,8" Command="{Binding LoadFileCommand}" />
            <Button Content="Ver Contenido" Style="{StaticResource BtnGhost}" Height="36" Margin="0,0,0,8" Command="{Binding ShowContentCommand}" />
            <Button Content="Ver Tabla" Style="{StaticResource BtnGhost}" Height="36" Margin="0,0,0,8" Command="{Binding ShowTableCommand}" />
            <Button Content="Gráfica de Barras" Style="{StaticResource BtnGhost}" Height="36" Margin="0,0,0,8" Command="{Binding ShowBarChartCommand}" />
            <Button Content="Gráfica de Pastel" Style="{StaticResource BtnGhost}" Height="36" Margin="0,0,0,8" Command="{Binding ShowPieChartCommand}" />

            <Border Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="8" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Info" FontWeight="SemiBold"/>
                    <TextBlock Text="Archivo:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding LoadedFileName}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Registros:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding RecordsCount}"/>
                    <TextBlock Text="Tipo:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding DetectedType}"/>
                    <TextBlock Text="Cargado:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding LoadedAt}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Panel central: contenido dinámico -->
        <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding ViewTitle}"/>
                    <TextBlock Text=" - " Margin="6,0"/>
                    <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="{Binding ViewSubtitle}"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Text content area -->
                    <TextBox Visibility="{Binding IsContentVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                             Text="{Binding FileContent}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas"/>

                    <!-- DataGrid area -->
                    <DataGrid Visibility="{Binding IsTableVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                              ItemsSource="{Binding Table.DefaultView}" AutoGenerateColumns="True" CanUserAddRows="False" IsReadOnly="True"/>

                    <!-- Charts area (placeholder controls) -->
                    <Grid Visibility="{Binding IsChartVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="6" Background="WhiteSmoke" CornerRadius="8" Padding="6">
                            <TextBlock Text="Bar chart placeholder"/>
                        </Border>
                        <Border Grid.Column="1" Margin="6" Background="WhiteSmoke" CornerRadius="8" Padding="6">
                            <TextBlock Text="Pie chart placeholder"/>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
