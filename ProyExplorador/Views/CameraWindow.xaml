<Window x:Class="ProyExplorador.Views.CameraWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cámara"
        Width="760" Height="560"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Marco con sombra -->
    <Border CornerRadius="14"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── TitleBar ── -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseDown="TitleBar_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F0F16" Offset="0"/>
                        <GradientStop Color="#13131C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel Margin="16,0,8,0">
                    <!-- Icono + título -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                        <Border Width="24" Height="24" CornerRadius="6" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C6DFA" Offset="0"/>
                                    <GradientStop Color="#3EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="📷" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Cámara"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Botón cerrar -->
                    <Button x:Name="BtnClose" Content="✕"
                            DockPanel.Dock="Right"
                            Click="BtnClose_Click"
                            Width="32" Height="32" FontSize="10"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BF3030"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Selector de cámara -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                HorizontalAlignment="Center" DockPanel.Dock="Left">
                        <TextBlock Text="Dispositivo:" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CmbDevices"
                                  Width="200" Height="26"
                                  FontSize="11"
                                  VerticalAlignment="Center"
                                  Background="#14141E"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="#1CFFFFFF"
                                  SelectionChanged="CmbDevices_SelectionChanged"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Área de vista previa ── -->
            <Border Grid.Row="1" Background="#080810" Margin="0">
                <Grid>
                    <!-- Imagen en tiempo real -->
                    <Image x:Name="ImgPreview"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Overlay "Sin señal" cuando la cámara está apagada -->
                    <Border x:Name="NoSignalOverlay"
                            Background="#0D0D14"
                            Visibility="Visible">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📷" FontSize="52"
                                       HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock x:Name="TxtStatus"
                                       Text="Cámara desactivada"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14" HorizontalAlignment="Center"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Flash de captura -->
                    <Border x:Name="FlashOverlay"
                            Background="White"
                            Opacity="0"
                            IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- ── Barra de acciones ── -->
            <Border Grid.Row="2"
                    Padding="20,14"
                    BorderBrush="#12FFFFFF"
                    BorderThickness="0,1,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0E0E14" Offset="0"/>
                        <GradientStop Color="#0C0C11" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Botón Iniciar -->
                    <Button Grid.Column="0" x:Name="BtnStart" Content="▶  Iniciar"
                            Click="BtnStart_Click"
                            Width="110" Height="36"
                            Margin="0,0,8,0"
                            Style="{StaticResource BtnPrimary}"/>

                    <!-- Botón Detener -->
                    <Button Grid.Column="1" x:Name="BtnStop" Content="⏹  Detener"
                            Click="BtnStop_Click"
                            IsEnabled="False"
                            Width="110" Height="36"
                            Margin="0,0,8,0"
                            Style="{StaticResource BtnGhost}"/>

                    <!-- Espacio flexible -->
                    <Border Grid.Column="2"/>

                    <!-- Botón Tomar Foto -->
                    <Button Grid.Column="3" x:Name="BtnCapture"
                            Content="📸  Tomar Foto"
                            Click="BtnCapture_Click"
                            IsEnabled="False"
                            Width="150" Height="40"
                            Margin="0,0,8,0"
                            Style="{StaticResource BtnPrimary}"/>

                    <!-- Botón Grabar Video -->
                    <Button Grid.Column="4" x:Name="BtnStartRecording"
                            Content="🔴  Grabar"
                            Click="BtnStartRecording_Click"
                            IsEnabled="False"
                            Width="120" Height="40"
                            Margin="0,0,8,0"
                            Style="{StaticResource BtnPrimary}"/>

                    <!-- Botón Detener Grabación -->
                    <Button Grid.Column="5" x:Name="BtnStopRecording"
                            Content="⏹  Parar"
                            Click="BtnStopRecording_Click"
                            IsEnabled="False"
                            Width="100" Height="40"
                            Style="{StaticResource BtnGhost}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
