<UserControl x:Class="ProyExplorador.Views.FileExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="768" d:DesignWidth="1060">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TOOLBAR ════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Nav buttons -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Path box — fills remaining space -->
                    <ColumnDefinition Width="*"/>
                    <!-- Folder/favorites -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Sort -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- View mode -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Navegación -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="←" Command="{Binding GoBackCommand}"
                            Style="{StaticResource BtnGhost}"
                            Width="34" Height="34" FontSize="16" ToolTip="Atrás"/>
                    <Button Content="→" Command="{Binding GoForwardCommand}"
                            Style="{StaticResource BtnGhost}"
                            Width="34" Height="34" FontSize="16" ToolTip="Adelante"
                            Margin="3,0"/>
                    <Button Content="↑" Command="{Binding GoUpCommand}"
                            Style="{StaticResource BtnGhost}"
                            Width="34" Height="34" FontSize="16" ToolTip="Subir"/>
                    <Button Content="↻" Command="{Binding RefreshCommand}"
                            Style="{StaticResource BtnGhost}"
                            Width="34" Height="34" FontSize="16" ToolTip="Actualizar"
                            Margin="3,0,0,0"/>
                </StackPanel>

                <!-- Ruta editable — se estira -->
                <Border Grid.Column="1"
                        Background="#14141E"
                        CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Margin="0,0,8,0">
                    <TextBox Text="{Binding CurrentPath, UpdateSourceTrigger=LostFocus}"
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             CaretBrush="{StaticResource AccentBrush}"
                             BorderThickness="0"
                             FontFamily="{StaticResource FontMain}"
                             FontSize="12"
                             Padding="12,8"
                             VerticalAlignment="Center"/>
                </Border>

                <!-- Nueva carpeta / favorito -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="📁+" Command="{Binding StartCreateFolderCommand}"
                            Style="{StaticResource BtnGhost}"
                            Padding="10,6" FontSize="12" ToolTip="Nueva carpeta"/>
                    <Button Content="☆" Command="{Binding AddCurrentToFavoritesCommand}"
                            Style="{StaticResource BtnGhost}"
                            Width="34" Height="34" FontSize="16" ToolTip="Añadir a favoritos"/>
                </StackPanel>

                <!-- Ordenar -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,4,0">
                    <TextBlock Text="Ordenar:"
                               FontFamily="{StaticResource FontMain}"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <Button Content="N" ToolTip="Ordenar por nombre"
                            Command="{Binding ChangeSortByCommand}" CommandParameter="Name"
                            Style="{StaticResource BtnGhost}" Width="28" Height="28" FontSize="11"/>
                    <Button Content="F" ToolTip="Ordenar por fecha"
                            Command="{Binding ChangeSortByCommand}" CommandParameter="Date"
                            Style="{StaticResource BtnGhost}" Width="28" Height="28" FontSize="11" Margin="2,0"/>
                    <Button Content="T" ToolTip="Ordenar por tamaño"
                            Command="{Binding ChangeSortByCommand}" CommandParameter="Size"
                            Style="{StaticResource BtnGhost}" Width="28" Height="28" FontSize="11"/>
                </StackPanel>

                <!-- Modos de vista -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="≡" ToolTip="Detalles"
                            Command="{Binding ChangeViewModeCommand}" CommandParameter="Details"
                            Style="{StaticResource BtnGhost}" Width="34" Height="34"/>
                    <Button Content="⊞" ToolTip="Cuadrícula"
                            Command="{Binding ChangeViewModeCommand}" CommandParameter="Grid"
                            Style="{StaticResource BtnGhost}" Width="34" Height="34" Margin="3,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ BREADCRUMB ═════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,5">
            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden">
                <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding}"
                                        Command="{Binding DataContext.NavigateToCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource BreadcrumbItem}"/>
                                <TextBlock Text="›"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="2,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ══ CONTENIDO: ÁRBOL + LISTA ══════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="180" MaxWidth="220"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: árbol de directorios + favoritos -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgSecondaryBrush}"
                    MinWidth="160"
                    Padding="6,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Favoritos -->
                    <TextBlock Grid.Row="0"
                               Text="FAVORITOS"
                               FontFamily="{StaticResource FontMain}"
                               FontSize="9.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="8,4,8,6"/>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Favorites}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateToCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource BtnGhost}"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,5" Margin="0,1">
                                    <TextBlock Text="{Binding}"
                                               FontFamily="{StaticResource FontMain}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Separador -->
                    <Rectangle Grid.Row="1" Height="1" Margin="8,4,8,4" VerticalAlignment="Bottom"
                               Fill="{StaticResource SeparatorBrush}"/>

                    <!-- Árbol de discos -->
                    <ScrollViewer Grid.Row="2" Style="{StaticResource MinimalScrollViewer}">
                        <TreeView ItemsSource="{Binding TreeNodes}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource DarkTreeViewItem}">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="13"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontFamily="{StaticResource FontMain}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Divisor luminoso -->
            <Rectangle Grid.Column="1" Fill="#18FFFFFF"/>

            <!-- Panel de archivos -->
            <Grid Grid.Column="2" Background="{StaticResource BgPrimaryBrush}">

                <!-- Barra "crear carpeta" inline -->
                <Border Background="{StaticResource BgCardBrush}"
                        CornerRadius="0" Padding="14,8"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="0,0,0,2"
                        VerticalAlignment="Top"
                        Visibility="{Binding IsCreatingFolder,
                            Converter={StaticResource BoolToVisibilityConverter}}"
                        Panel.ZIndex="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📁" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding NewFolderName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Padding="10,6"
                                 VerticalAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"  Command="{Binding ConfirmCreateFolderCommand}"/>
                                <KeyBinding Key="Escape" Command="{Binding CancelCreateFolderCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Content="Crear" Command="{Binding ConfirmCreateFolderCommand}"
                                    Style="{StaticResource BtnPrimary}"
                                    Padding="14,6" FontSize="12"/>
                            <Button Content="Cancelar" Command="{Binding CancelCreateFolderCommand}"
                                    Style="{StaticResource BtnGhost}"
                                    Padding="10,6" FontSize="12" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Vista DETALLES -->
                <ListView ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem}"
                          Style="{StaticResource ModernListView}"
                          Padding="8,4"
                          Visibility="{Binding ViewMode, Converter={StaticResource ViewModeToVisibilityConverter},
                                       ConverterParameter=Details}">
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Abrir" Command="{Binding OpenItemCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                          RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                <MenuItem.Icon>
                                    <TextBlock Text="📂" FontSize="13"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparator}"/>
                            <MenuItem Header="Nueva carpeta" Command="{Binding StartCreateFolderCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="📁" FontSize="13"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Añadir a favoritos" Command="{Binding AddCurrentToFavoritesCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="☆" FontSize="13"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparator}"/>
                            <MenuItem Header="Eliminar" Command="{Binding DeleteItemCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                          RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🗑️" FontSize="13"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="32">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Icon}" FontSize="16"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Nombre"     Width="240"
                                            DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Tipo"       Width="100"
                                            DisplayMemberBinding="{Binding ItemType}"/>
                            <GridViewColumn Header="Tamaño"     Width="80"
                                            DisplayMemberBinding="{Binding FormattedSize}"/>
                            <GridViewColumn Header="Modificado" Width="130"
                                            DisplayMemberBinding="{Binding DateModified,
                                                StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenItemCommand}"
                                      CommandParameter="{Binding SelectedItem,
                                          RelativeSource={RelativeSource AncestorType=ListView}}"/>
                    </ListView.InputBindings>
                </ListView>

                <!-- Vista CUADRÍCULA -->
                <ScrollViewer Style="{StaticResource MinimalScrollViewer}"
                              Padding="10"
                              Visibility="{Binding ViewMode, Converter={StaticResource ViewModeToVisibilityConverter},
                                           ConverterParameter=Grid}">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenItemCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="4" Padding="0">
                                    <Border MinWidth="110" Width="120" MinHeight="100" Height="108"
                                            Background="{StaticResource BgCardBrush}"
                                            CornerRadius="12"
                                            BorderBrush="#0EFFFFFF"
                                            BorderThickness="1"
                                            Padding="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                        <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}" FontSize="34"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource FontMain}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextAlignment="Center"
                                                       Margin="0,7,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Busy overlay -->
                <Border Background="#A0000000"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="14" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#207C6DFA" Offset="0"/>
                                    <GradientStop Color="#203EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="⏳" FontSize="26"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontFamily="{StaticResource FontMain}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Estado vacío -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsBusy}"   Value="False"/>
                                        <Condition Binding="{Binding Items.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📭" FontSize="52" HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Text="Carpeta vacía"
                               FontFamily="{StaticResource FontMain}"
                               FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>