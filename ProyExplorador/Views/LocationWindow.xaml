<Window x:Class="ProyExplorador.Views.LocationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ver Ubicación"
        Width="900" Height="640"
        MinWidth="700" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource FontMain}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="14"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.55"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Latitud" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtLatitud" Text="-" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="24,0,0,0">
                    <TextBlock Text="Longitud" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtLongitud" Text="-" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="24,0,0,0">
                    <TextBlock Text="Estado GPS" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtEstado" Text="Desconocido" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="24,0,0,0">
                    <TextBlock Text="Precisión (m)" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtPrecision" Text="-" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Background="#0B0000" Margin="0,0,12,0">
                    <Grid>
                        <!-- WebView2 placeholder -->
                        <Grid x:Name="MapHost" Background="#0F0F12">
                            <TextBlock Text="Mapa cargando..." Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1">
                    <Button x:Name="BtnActualizar" Content="Actualizar Ubicación" Click="BtnActualizar_Click" Style="{StaticResource BtnPrimary}"/>
                    <Button x:Name="BtnAbrirMapa" Content="Abrir en Google Maps" Click="BtnAbrirMapa_Click" Margin="0,8,0,0" Style="{StaticResource BtnSecondary}"/>
                    <Border Margin="0,12,0,0" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Detalles" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Latitud:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,8,0,0"/>
                            <TextBlock x:Name="DetalleLat" Text="-" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Longitud:" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,8,0,0"/>
                            <TextBlock x:Name="DetalleLong" Text="-" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Precisión (m):" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,8,0,0"/>
                            <TextBlock x:Name="DetallePrec" Text="-" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StatusBar Grid.Row="2" Margin="0,8,0,0">
                <StatusBarItem>
                    <TextBlock x:Name="StatusText" Text="Esperando ubicación..." Foreground="{StaticResource TextMutedBrush}"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</Window>