<Window x:Class="ProyExplorador.Views.LocationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ver Ubicación"
        Width="900" Height="640"
        MinWidth="700" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource FontMain}"
        Loaded="LocationWindow_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="14"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.55"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>



            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,12,0,0">
                <UniformGrid Columns="2" Rows="2" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="📍 Latitud" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock x:Name="TxtLatitud" Text="-" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="📍 Longitud" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock x:Name="TxtLongitud" Text="-" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="🌎 Ciudad" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock x:Name="TxtCiudad" Text="-" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="📡 Estado" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock x:Name="TxtEstado" Text="Desconocido" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
                    <Button x:Name="BtnActualizar" Content="🔄 Actualizar ubicación" Click="BtnActualizar_Click" Style="{StaticResource BtnPrimary}"/>
                    <Button x:Name="BtnAbrirMapa" Content="🗺️ Abrir en Google Maps" Click="BtnAbrirMapa_Click" Style="{StaticResource BtnSecondary}" Margin="12,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <StatusBar Grid.Row="2" Margin="0,8,0,0">
                <StatusBarItem>
                    <TextBlock x:Name="StatusText" Text="Esperando ubicación..." Foreground="{StaticResource TextMutedBrush}"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</Window>