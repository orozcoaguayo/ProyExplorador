<Window x:Class="ProyExplorador.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ProyExplorador.ViewModels"
        xmlns:views="clr-namespace:ProyExplorador.Views"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="840" Width="1300"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FileExplorerViewModel}">
            <views:FileExplorerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MultimediaViewModel}">
            <views:MultimediaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
            <views:SearchView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CleanupViewModel}">
            <views:CleanupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatsViewModel}">
            <views:StatsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FileReaderViewModel}">
            <views:FileReaderView/>
        </DataTemplate>
    </Window.Resources>

    <!-- Marco exterior con sombra profunda -->
    <Border x:Name="WindowBorder"
            CornerRadius="14"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="50" ShadowDepth="10" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 TITLEBAR — Windows 11 custom chrome style
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    CornerRadius="14,14,0,0"
                    MouseDown="TitleBar_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F0F16" Offset="0"/>
                        <GradientStop Color="#13131C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" MinWidth="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ─ Logo  ─ -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0">
                        <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C6DFA" Offset="0"/>
                                    <GradientStop Color="#3EC9C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="P" Foreground="White" FontWeight="Bold"
                                       FontSize="14" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontMain}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ProyExplorador"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ─ Búsqueda global ─ -->
                    <Border Grid.Column="1"
                            Background="#14141E"
                            CornerRadius="9"
                            BorderBrush="#1CFFFFFF"
                            BorderThickness="1"
                            Margin="12,8"
                            MaxWidth="480"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍"
                                       FontSize="12"
                                       Opacity="0.45"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     BorderThickness="0"
                                     FontFamily="{StaticResource FontMain}"
                                     FontSize="13"
                                     VerticalAlignment="Center"
                                     Padding="0,7">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding GlobalSearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <!-- Placeholder -->
                            <TextBlock Grid.Column="1"
                                       Text="Buscar archivos y carpetas..."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="{StaticResource FontMain}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Padding="0,7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- ─ Window controls ─ -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="6,0,10,0">
                        <Button x:Name="BtnMinimize" Content="─"
                                Click="BtnMinimize_Click"
                                Style="{StaticResource BtnGhost}"
                                Width="34" Height="34" FontSize="11"
                                ToolTip="Minimizar"/>
                        <Button x:Name="BtnMaximize" Content="⬜"
                                Click="BtnMaximize_Click"
                                Style="{StaticResource BtnGhost}"
                                Width="34" Height="34" FontSize="10"
                                Margin="2,0" ToolTip="Maximizar"/>
                        <Button x:Name="BtnClose" Content="✕"
                                Click="BtnClose_Click"
                                Width="34" Height="34" FontSize="11"
                                ToolTip="Cerrar">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BF3030"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 CUERPO: SIDEBAR + CONTENIDO
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─────────────────  SIDEBAR  ───────────────────── -->
                <Border Grid.Column="0"
                        CornerRadius="0,0,0,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0E0E14" Offset="0"/>
                            <GradientStop Color="#0C0C11" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nav items -->
                        <ScrollViewer Grid.Row="0"
                                      Style="{StaticResource MinimalScrollViewer}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,12,0,8">
                            <ItemsControl ItemsSource="{Binding NavItems}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.NavigateCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                Margin="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Root"
                                                                            CornerRadius="10"
                                                                            Margin="8,2"
                                                                            Padding="10,9"
                                                                            ClipToBounds="False">
                                                        <Border.Background>
                                                            <SolidColorBrush x:Name="RootBg" Color="Transparent"/>
                                                        </Border.Background>
                                                        <Grid>
                                                            <!-- Indicador de acento lateral -->
                                                            <Border x:Name="Pill"
                                                                    Width="3"
                                                                    CornerRadius="0,3,3,0"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Stretch"
                                                                    Margin="-10,4,0,4"
                                                                    Background="Transparent"/>

                                                            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                                                <!-- Icono con fondo suave si activo -->
                                                                <Border x:Name="IconWrap"
                                                                        Width="26" Height="26"
                                                                        CornerRadius="7"
                                                                        Background="Transparent">
                                                                    <TextBlock Text="{Binding Icon}"
                                                                               FontSize="14"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock x:Name="Label"
                                                                           Text="{Binding Title}"
                                                                           FontFamily="{StaticResource FontMain}"
                                                                           FontSize="13"
                                                                           VerticalAlignment="Center"
                                                                           Margin="10,0,6,0"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <!-- Activo -->
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter TargetName="Root"    Property="Background" Value="#1B1B28"/>
                                                            <Setter TargetName="Pill" Property="Background" Value="#7C6DFA"/>
                                                            <Setter TargetName="Label"   Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                            <Setter TargetName="Label"   Property="FontWeight" Value="SemiBold"/>
                                                            <Setter TargetName="IconWrap" Property="Background" Value="#1A7C6DFA"/>
                                                        </DataTrigger>
                                                        <!-- Hover -->
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#16162A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#20203A"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Footer del sidebar -->
                        <Border Grid.Row="1"
                                Padding="12,11"
                                BorderBrush="#12FFFFFF"
                                BorderThickness="0,1,0,0">
                            <StackPanel>
                                <!-- Botón Editor de Fotos -->
                                <Button Content="🖼️  Editor de Fotos"
                                        Command="{Binding OpenPhotoEditorCommand}"
                                        Cursor="Hand"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource BtnSecondary}"
                                        ToolTip="Abrir editor de fotos"/>

                                <!-- Botón Cámara -->
                                <Button Content="📷  Cámara"
                                        Command="{Binding OpenCameraCommand}"
                                        Cursor="Hand"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource BtnPrimary}"
                                        ToolTip="Abrir cámara web"/>

                                <DockPanel LastChildFill="True">
                                <!-- Avatar con gradiente -->
                                <Border Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C6DFA" Offset="0"/>
                                            <GradientStop Color="#3EC9C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="{Binding UserInitial}" Foreground="White"
                                               FontWeight="Bold" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontMain}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center" MinWidth="0">
                                    <TextBlock Text="{Binding UserName}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="{StaticResource FontMain}"
                                               FontSize="12" FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="140"/>
                                    <TextBlock Text=".NET 8 · WPF"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="{StaticResource FontMain}"
                                               FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DockPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Divisor luminoso -->
                <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right"
                           VerticalAlignment="Stretch">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent"    Offset="0"/>
                            <GradientStop Color="#20FFFFFF"      Offset="0.5"/>
                            <GradientStop Color="Transparent"    Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- ─────────────────  ÁREA PRINCIPAL  ─────────────── -->
                <Border Grid.Column="1"
                        Background="{StaticResource BgPrimaryBrush}"
                        CornerRadius="0,0,14,0">
                    <Grid>
                        <!-- Vista actual — transición por código -->
                        <ContentControl x:Name="MainContent"
                                        Content="{Binding CurrentViewModel}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Focusable="False"/>

                        <!-- Loading overlay global -->
                        <Border x:Name="LoadingOverlay"
                                Background="#B0000000"
                                CornerRadius="0,0,14,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Visibility="{Binding CurrentViewModel.IsBusy,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Width="64" Height="64" CornerRadius="16"
                                        Margin="0,0,0,18">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1E7C6DFA" Offset="0"/>
                                            <GradientStop Color="#1E3EC9C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⏳" FontSize="30"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding CurrentViewModel.StatusMessage}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="{StaticResource FontMain}"
                                           FontSize="14" FontWeight="Medium"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Por favor espere..."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource FontMain}"
                                           FontSize="12" HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Toast de notificación (popup inferior derecho) -->
                        <Border x:Name="ToastPanel"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Right"
                                Margin="0,0,20,20"
                                Visibility="Collapsed"
                                Opacity="0"
                                RenderTransformOrigin="0.5,1">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ToastTranslate" Y="40"/>
                            </Border.RenderTransform>
                            <Border Background="#1E202E"
                                    BorderBrush="#30FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16,12"
                                    MinWidth="260">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="24"
                                                      ShadowDepth="4" Opacity="0.45"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ToastIcon" Text="ℹ️"
                                               FontSize="18" VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="ToastTitle" Text="Notificación"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontFamily="{StaticResource FontMain}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="ToastMessage" Text=""
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="{StaticResource FontMain}"
                                                   FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>