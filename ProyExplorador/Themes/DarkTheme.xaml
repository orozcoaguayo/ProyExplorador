<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ══════════════════════════════════════════════════════════
         PALETA PREMIUM — Fluent / Windows 11 inspired
    ══════════════════════════════════════════════════════════ -->

    <!--  Base superficies  -->
    <Color x:Key="BgPrimaryColor">#0C0C10</Color>
    <Color x:Key="BgSecondaryColor">#131318</Color>
    <Color x:Key="BgTertiaryColor">#18181F</Color>
    <Color x:Key="BgCardColor">#1C1C24</Color>
    <Color x:Key="BgHoverColor">#232330</Color>
    <Color x:Key="BgSelectedColor">#2B2B3C</Color>
    <Color x:Key="BgActiveColor">#33334A</Color>
    <Color x:Key="SidebarColor">#0F0F14</Color>

    <!--  Acentos  -->
    <Color x:Key="AccentPrimaryColor">#7C6DFA</Color>
    <Color x:Key="AccentLightColor">#9D91FB</Color>
    <Color x:Key="AccentDarkColor">#5A4DE8</Color>
    <Color x:Key="AccentSecondaryColor">#3EC9C0</Color>
    <Color x:Key="AccentDangerColor">#F05252</Color>
    <Color x:Key="AccentWarningColor">#F0A732</Color>
    <Color x:Key="AccentSuccessColor">#4CAF7A</Color>
    <Color x:Key="AccentInfoColor">#4AA8F0</Color>

    <!--  Texto  -->
    <Color x:Key="TextPrimaryColor">#F2F2F8</Color>
    <Color x:Key="TextSecondaryColor">#9898B0</Color>
    <Color x:Key="TextMutedColor">#6A6A82</Color>
    <Color x:Key="TextAccentColor">#A89FFC</Color>

    <!--  Bordes  -->
    <Color x:Key="BorderColor">#28283A</Color>
    <Color x:Key="BorderSubtleColor">#1C1C28</Color>
    <Color x:Key="SeparatorColor">#181820</Color>

    <!--  Glassmorphism  -->
    <Color x:Key="GlassColor">#CC141420</Color>
    <Color x:Key="GlassBorderColor">#33FFFFFF</Color>
    <Color x:Key="GlassFrostColor">#E61C1C28</Color>

    <!-- ── SOLID BRUSHES ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgPrimaryBrush"    Color="{StaticResource BgPrimaryColor}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush"  Color="{StaticResource BgSecondaryColor}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush"   Color="{StaticResource BgTertiaryColor}"/>
    <SolidColorBrush x:Key="BgCardBrush"       Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgHoverBrush"      Color="{StaticResource BgHoverColor}"/>
    <SolidColorBrush x:Key="BgSelectedBrush"   Color="{StaticResource BgSelectedColor}"/>
    <SolidColorBrush x:Key="BgActiveBrush"     Color="{StaticResource BgActiveColor}"/>
    <SolidColorBrush x:Key="SidebarBrush"      Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="GlassBrush"        Color="{StaticResource GlassColor}"/>
    <SolidColorBrush x:Key="GlassBorderBrush"  Color="{StaticResource GlassBorderColor}"/>

    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush"   Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush"    Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="AccentSecBrush"     Color="{StaticResource AccentSecondaryColor}"/>
    <SolidColorBrush x:Key="DangerBrush"        Color="{StaticResource AccentDangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush"       Color="{StaticResource AccentWarningColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"       Color="{StaticResource AccentSuccessColor}"/>
    <SolidColorBrush x:Key="InfoBrush"          Color="{StaticResource AccentInfoColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextAccentBrush"    Color="{StaticResource TextAccentColor}"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"  Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush"     Color="{StaticResource SeparatorColor}"/>

    <!-- ── GRADIENT BRUSHES ─────────────────────────────────────── -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7C6DFA" Offset="0"/>
        <GradientStop Color="#3EC9C0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientHBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#7C6DFA" Offset="0"/>
        <GradientStop Color="#5A9DFA" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1E1E2C" Offset="0"/>
        <GradientStop Color="#16161E" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0F0F16" Offset="0"/>
        <GradientStop Color="#0C0C12" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glassmorphism panel -->
    <LinearGradientBrush x:Key="GlassPanelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3018182A" Offset="0"/>
        <GradientStop Color="#5012121E" Offset="1"/>
    </LinearGradientBrush>

    <!-- Shimmer para skeleton loading -->
    <LinearGradientBrush x:Key="SkeletonBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1E1E2A" Offset="0"/>
        <GradientStop Color="#28283A" Offset="0.5"/>
        <GradientStop Color="#1E1E2A" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── TIPOGRAFÍA ────────────────────────────────────────────── -->
    <FontFamily x:Key="FontMain">Segoe UI Variable Display, Segoe UI Variable, Segoe UI, Sans-Serif</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Code, Consolas, Courier New, Monospace</FontFamily>

    <sys:Double x:Key="FontSizeXS">10</sys:Double>
    <sys:Double x:Key="FontSizeSM">12</sys:Double>
    <sys:Double x:Key="FontSizeMD">14</sys:Double>
    <sys:Double x:Key="FontSizeLG">16</sys:Double>
    <sys:Double x:Key="FontSizeXL">20</sys:Double>
    <sys:Double x:Key="FontSizeXXL">26</sys:Double>
    <sys:Double x:Key="FontSizeHero">36</sys:Double>

    <!-- ── CORNER RADIUS ────────────────────────────────────────── -->
    <CornerRadius x:Key="RadiusXS">4</CornerRadius>
    <CornerRadius x:Key="RadiusSM">6</CornerRadius>
    <CornerRadius x:Key="RadiusMD">10</CornerRadius>
    <CornerRadius x:Key="RadiusLG">14</CornerRadius>
    <CornerRadius x:Key="RadiusXL">20</CornerRadius>
    <CornerRadius x:Key="RadiusFull">100</CornerRadius>

    <!-- ── SPACING ───────────────────────────────────────────────── -->
    <Thickness x:Key="PaddingXS">6,4</Thickness>
    <Thickness x:Key="PaddingSM">10,7</Thickness>
    <Thickness x:Key="PaddingMD">16,11</Thickness>
    <Thickness x:Key="PaddingLG">22,16</Thickness>
    <Thickness x:Key="CardPadding">20,18</Thickness>

    <!-- Margin / gap tokens  (Small=8  Medium=12  Large=16  XL=24  Section=28) -->
    <Thickness x:Key="MarginSM">8</Thickness>
    <Thickness x:Key="MarginMD">12</Thickness>
    <Thickness x:Key="MarginLG">16</Thickness>
    <Thickness x:Key="MarginXL">24</Thickness>
    <Thickness x:Key="MarginSection">28,24,28,28</Thickness>
    <Thickness x:Key="CardGap">0,0,12,12</Thickness>
    <Thickness x:Key="CardGapLast">0,0,0,12</Thickness>

</ResourceDictionary>
